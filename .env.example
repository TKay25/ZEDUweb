// frontend/.env.example
# ==============================================
# ZEDU PLATFORM - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===== APPLICATION CONFIG =====
VITE_APP_NAME=ZEDU
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Zimbabwe Educational Platform
VITE_APP_URL=http://localhost:3000
VITE_APP_ENV=development
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_CDN_URL=http://localhost:5000/uploads

# ===== AUTHENTICATION =====
VITE_JWT_SECRET=your-super-secret-jwt-key-change-this
VITE_JWT_EXPIRY=7d
VITE_REFRESH_TOKEN_EXPIRY=30d

# ===== OAUTH PROVIDERS =====
# Google OAuth
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Facebook OAuth
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_APP_SECRET=

# Microsoft OAuth
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_CLIENT_SECRET=

# GitHub OAuth
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_CLIENT_SECRET=

# ===== PAYMENT GATEWAYS =====
# Stripe
VITE_STRIPE_PUBLIC_KEY=
VITE_STRIPE_SECRET_KEY=

# PayNow (Zimbabwe)
VITE_PAYNOW_INTEGRATION_KEY=
VITE_PAYNOW_RETURN_URL=

# EcoCash (Zimbabwe)
VITE_ECOCASH_API_KEY=
VITE_ECOCASH_API_URL=https://api.ecocash.co.zw

# ===== VIDEO CALLING =====
# Agora.io
VITE_AGORA_APP_ID=
VITE_AGORA_APP_CERTIFICATE=

# Video SDK
VITE_VIDEO_SDK_KEY=
VITE_VIDEO_SDK_SECRET=

# ===== AI SERVICES =====
# OpenAI
VITE_OPENAI_API_KEY=
VITE_OPENAI_ORG_ID=
VITE_OPENAI_MODEL=gpt-4

# Hugging Face
VITE_HUGGINGFACE_API_KEY=
VITE_HUGGINGFACE_MODEL=microsoft/DialoGPT-medium

# ===== CLOUD STORAGE =====
# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=

# AWS S3
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
VITE_AWS_REGION=af-south-1
VITE_AWS_BUCKET_NAME=

# ===== EMAIL SERVICE =====
# SMTP Configuration
VITE_SMTP_HOST=
VITE_SMTP_PORT=
VITE_SMTP_USER=
VITE_SMTP_PASS=
VITE_SMTP_FROM_EMAIL=
VITE_SMTP_FROM_NAME=

# ===== SMS SERVICE =====
VITE_SMS_API_KEY=
VITE_SMS_API_SECRET=
VITE_SMS_SENDER_ID=ZEDU
VITE_SMS_API_URL=

# ===== ANALYTICS =====
VITE_GOOGLE_ANALYTICS_ID=
VITE_GOOGLE_TAG_MANAGER_ID=
VITE_FACEBOOK_PIXEL_ID=
VITE_MIXPANEL_TOKEN=
VITE_SENTRY_DSN=

# ===== FEATURE FLAGS =====
VITE_ENABLE_AI_TUTOR=true
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_SCHOLARSHIPS=true
VITE_ENABLE_CERTIFICATES=true
VITE_ENABLE_CAREER_PATH=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_TWO_FACTOR=true

# ===== PWA CONFIG =====
VITE_PWA_NAME=ZEDU
VITE_PWA_SHORT_NAME=ZEDU
VITE_PWA_DESCRIPTION=Zimbabwe Educational Platform
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#ffffff
VITE_PWA_DISPLAY=standalone
VITE_PWA_ORIENTATION=portrait
VITE_PWA_SCOPE=/
VITE_PWA_START_URL=/

# ===== CACHING =====
VITE_CACHE_TTL=300000
VITE_QUERY_STALE_TIME=300000
VITE_QUERY_CACHE_TIME=600000

# ===== RATE LIMITING =====
VITE_RATE_LIMIT_MAX=100
VITE_RATE_LIMIT_WINDOW_MS=60000

# ===== DEBUGGING =====
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
VITE_ENABLE_REDUX_DEVTOOLS=true
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true
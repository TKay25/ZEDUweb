# Flask Backend Environment Variables
FLASK_ENV=production
FLASK_APP=wsgi.py
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost/zedu

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600

# API Settings
API_DEBUG=False
API_CORS_ORIGINS=http://localhost:3000,https://zedu-frontend.onrender.com

# ===== OAUTH PROVIDERS =====
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_FACEBOOK_APP_SECRET=your-facebook-app-secret
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
VITE_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
VITE_GITHUB_CLIENT_ID=your-github-client-id
VITE_GITHUB_CLIENT_SECRET=your-github-client-secret

# ===== PAYMENT GATEWAYS =====
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
VITE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_PAYNOW_INTEGRATION_KEY=your-paynow-integration-key
VITE_PAYNOW_RETURN_URL=http://localhost:3000/payments/return
VITE_ECOCASH_API_KEY=your-ecocash-api-key
VITE_ECOCASH_API_URL=https://api.ecocash.co.zw

# ===== VIDEO CALLING =====
VITE_AGORA_APP_ID=your-agora-app-id
VITE_AGORA_APP_CERTIFICATE=your-agora-certificate
VITE_VIDEO_SDK_KEY=your-video-sdk-key
VITE_VIDEO_SDK_SECRET=your-video-sdk-secret

# ===== AI SERVICES =====
VITE_OPENAI_API_KEY=sk-your-openai-api-key
VITE_OPENAI_ORG_ID=your-openai-org-id
VITE_OPENAI_MODEL=gpt-4
VITE_HUGGINGFACE_API_KEY=your-huggingface-api-key
VITE_HUGGINGFACE_MODEL=microsoft/DialoGPT-medium

# ===== CLOUD STORAGE =====
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_API_KEY=your-api-key
VITE_CLOUDINARY_API_SECRET=your-api-secret
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-key
VITE_AWS_REGION=af-south-1
VITE_AWS_BUCKET_NAME=zedu-storage

# ===== EMAIL SERVICE =====
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your-email@gmail.com
VITE_SMTP_PASS=your-app-password
VITE_SMTP_FROM_EMAIL=noreply@zedu.co.zw
VITE_SMTP_FROM_NAME=ZEDU Platform

# ===== SMS SERVICE =====
VITE_SMS_API_KEY=your-sms-api-key
VITE_SMS_API_SECRET=your-sms-api-secret
VITE_SMS_SENDER_ID=ZEDU
VITE_SMS_API_URL=https://api.sms.co.zw

# ===== ANALYTICS =====
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXX
VITE_FACEBOOK_PIXEL_ID=1234567890
VITE_MIXPANEL_TOKEN=your-mixpanel-token
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ===== FEATURE FLAGS =====
VITE_ENABLE_AI_TUTOR=true
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_SCHOLARSHIPS=true
VITE_ENABLE_CERTIFICATES=true
VITE_ENABLE_CAREER_PATH=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_TWO_FACTOR=true

# ===== PWA CONFIG =====
VITE_PWA_NAME=ZEDU
VITE_PWA_SHORT_NAME=ZEDU
VITE_PWA_DESCRIPTION=Zimbabwe Educational Platform
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#ffffff
VITE_PWA_DISPLAY=standalone
VITE_PWA_ORIENTATION=portrait
VITE_PWA_SCOPE=/
VITE_PWA_START_URL=/

# ===== CACHING =====
VITE_CACHE_TTL=300000
VITE_QUERY_STALE_TIME=300000
VITE_QUERY_CACHE_TIME=600000

# ===== RATE LIMITING =====
VITE_RATE_LIMIT_MAX=100
VITE_RATE_LIMIT_WINDOW_MS=60000

# ===== DEBUGGING =====
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
VITE_ENABLE_REDUX_DEVTOOLS=true
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true